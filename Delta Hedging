plt.title("Delta Hedging Results: ITC Call Option Simulation", fontsize=15, fontweight="bold", pad=18)

interpretation_text = (
    "Interpretation: Delta determines the stock hedge needed for the long call. "
    "Gamma explains why the hedge must be adjusted as the stock moves. "
